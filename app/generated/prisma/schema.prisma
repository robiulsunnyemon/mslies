datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
  output               = "app/generated/prisma"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  fullname      String
  passwordHash  String
  isVerified    Boolean        @default(false)
  files         File[]
  mcqSets       MCQSet[]
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
}

model OTP {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      String // "SIGNUP", "FORGOT_PASSWORD"
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model File {
  id               String   @id @default(uuid())
  filename         String
  filepath         String
  fileType         String // "PDF" or "PPTX"
  status           String // "PENDING", "EMBEDDED", "COMPLETED", "FAILED"
  vectorCollection String? // Optional: To store which ChromaDB collection this file belongs to
  userId           String? // Optional for backward compatibility during migration
  user             User?    @relation(fields: [userId], references: [id])
  mcqSets          MCQSet[]
  createdAt        DateTime @default(now())
}

model MCQSet {
  id        String     @id @default(uuid())
  fileId    String
  file      File       @relation(fields: [fileId], references: [id], onDelete: Cascade)
  userId    String? // Optional for backward compatibility
  user      User?      @relation(fields: [userId], references: [id])
  topicName String? // Optional: if MCQ was generated based on a specific topic
  questions Question[]
  createdAt DateTime   @default(now())
}

model Question {
  id            String @id @default(uuid())
  mcqSetId      String
  mcqSet        MCQSet @relation(fields: [mcqSetId], references: [id], onDelete: Cascade)
  questionText  String
  options       Json // Array of options, e.g., ["A", "B", "C", "D"]
  correctAnswer String // The correct option
  explanation   String // Explanation for the answer
}
